{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "deckboss-net-landing",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "BETA_SIGNUPS",
      "id": "2029d51fe0584b7bbd8304211e6dbbd8"
    }
  ]
}
